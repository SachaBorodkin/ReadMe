<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ReadMe.ReaderPage"
             Title="Reader"
             BackgroundColor="White">

       <Shell.TitleView>
              <Grid HorizontalOptions="FillAndExpand" BackgroundColor="#0F172A" Padding="12,8" ColumnDefinitions="Auto, *, Auto">
                     <Button Grid.Column="0"
                                   Text="≡"
                                   Clicked="OnMenuClicked"
                                   BackgroundColor="Transparent"
                                   TextColor="White"
                                   FontSize="22"
                                   WidthRequest="42"
                                   HeightRequest="42"
                                   Padding="0" />

                     <Label Grid.Column="1"
                               HorizontalOptions="Center"
                               VerticalOptions="Center"
                               FontSize="22"
                               FontAttributes="Bold">
                            <Label.FormattedText>
                                   <FormattedString>
                                          <Span Text="Only" TextColor="White" />
                                          <Span Text="Books" TextColor="#14B8A6" />
                                   </FormattedString>
                            </Label.FormattedText>
                     </Label>

                     <BoxView Grid.Column="2" WidthRequest="42" HeightRequest="1" Opacity="0" />
              </Grid>
       </Shell.TitleView>

    <Grid RowDefinitions="Auto, *, Auto" Padding="16" RowSpacing="12">
        <VerticalStackLayout Grid.Row="0" Spacing="6" HorizontalOptions="Center">
            <Label Text="{Binding CurrentPageDisplay}"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="#0F172A"
                   HorizontalTextAlignment="Center" />
            <Label Text="{Binding CurrentChapterTitle}"
                   FontSize="13"
                   TextColor="#64748B"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

        <Frame Grid.Row="1"
               CornerRadius="22"
               Padding="0"
               HasShadow="False"
               BorderColor="#E2E8F0"
               BackgroundColor="White">
            <WebView x:Name="ContentWebView"
                     BackgroundColor="White" />
        </Frame>

        <Grid Grid.Row="2" ColumnDefinitions="Auto, *, Auto" ColumnSpacing="12">
            <Button Grid.Column="0"
                    Text="←"
                    Clicked="OnPreviousClicked"
                    BackgroundColor="#0F172A"
                    TextColor="White"
                    CornerRadius="14"
                    WidthRequest="72"
                    HeightRequest="46" />

            <Frame Grid.Column="1"
                   CornerRadius="14"
                   Padding="0"
                   HasShadow="False"
                   BorderColor="#CBD5E1"
                   BackgroundColor="White"
                   HorizontalOptions="Center"
                   WidthRequest="72">
                <Label Text="{Binding CurrentPageNumber}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="16"
                       FontAttributes="Bold"
                       TextColor="#0F172A"
                       Padding="0,10" />
            </Frame>

            <Button Grid.Column="2"
                    Text="→"
                    Clicked="OnNextClicked"
                    BackgroundColor="#0F172A"
                    TextColor="White"
                    CornerRadius="14"
                    WidthRequest="72"
                    HeightRequest="46" />
        </Grid>
    </Grid>

</ContentPage>